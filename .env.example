# RHOAI Amplitude Dashboard — Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Then source it before running:
#   source .env

# Amplitude API credentials
# Get keys from: Amplitude > Organization Settings > API Keys > RHODS Instances
# Required for all commands (report, list, backfill)
export AMPLITUDE_API_KEY="your_amplitude_api_key_here"
export AMPLITUDE_SECRET_KEY="your_amplitude_secret_key_here"
